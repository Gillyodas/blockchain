    %% ============================================================
    %% RELATIONSHIPS — COMPOSITION (◆)
    %% ============================================================

    %% GiayPhep thuộc YeuCauDangKy trong giai đoạn đăng ký
    %% Sau khi Admin duyệt → chuyển sang CSDT/NTD
    %% Tùy LoaiToChucDangKy, chỉ 1 trong 2 loại giấy phép tồn tại
    YeuCauDangKy "1" *-- "0..*" GiayPhepCSDT : giai đoạn đăng ký
    YeuCauDangKy "1" *-- "0..*" GiayPhepNhaTuyenDung : giai đoạn đăng ký

    %% GiayPhep thuộc CSDT/NTD sau khi duyệt thành công
    CoSoDaoTao "1" *-- "0..*" GiayPhepCSDT : sau khi duyệt
    NhaTuyenDung "1" *-- "0..*" GiayPhepNhaTuyenDung : sau khi duyệt

    CoSoDaoTao "1" *-- "1" UyTinToChuc
    NhaTuyenDung "1" *-- "0..*" ThongTinTuyenDung
    GiayPhepCSDT "1" *-- "1" ThongTinChuKySo
    GiayPhepNhaTuyenDung "1" *-- "1" ThongTinChuKySo
    HoSoUngTuyen "1" *-- "1..*" BangCapUngTuyen

    %% ============================================================
    %% RELATIONSHIPS — AGGREGATION (◇)
    %% ============================================================

    CoSoDaoTao "1" o-- "0..*" BangCap : cấp

    %% ============================================================
    %% RELATIONSHIPS — ASSOCIATION (many-to-many)
    %% ============================================================

    CoSoDaoTao "0..*" -- "0..*" SinhVien : quản lý

    %% ============================================================
    %% RELATIONSHIPS — DIRECTED ASSOCIATION (→)
    %% ============================================================

    CoSoDaoTao --> LinhVuc : biết tới
    BangCap --> LinhVuc : thuộc
    BangCap --> LoaiBangCap
    BangCap --> LyDoHuy
    BangCap --> LyDoThuHoi
    BangCap --> TrangThaiBlockchain
    BangCap --> TrangThaiBangCap

    SinhVien "1" --> "0..*" HoSoUngTuyen : nộp

    NhatKyXacMinh --> NhaTuyenDung : thực hiện bởi
    NhatKyXacMinh --> BangCap : xác minh
    NhatKyXacMinh --> KetQuaXacMinhEnum

    ThongTinTuyenDung --> LinhVuc : thuộc
    ThongTinTuyenDung "1" --> "0..*" KetQuaPhanTich : có nhiều lần phân tích

    HoSoUngTuyen --> ThongTinTuyenDung : ứng tuyển vào
    HoSoUngTuyen --> TrangThaiUngTuyen

    BangCapUngTuyen --> BangCap : tham chiếu

    BaoCaoGianLan --> BangCap : báo cáo về
    BaoCaoGianLan --> SinhVien : báo cáo bởi SV
    BaoCaoGianLan --> NhaTuyenDung : báo cáo bởi NTD
    BaoCaoGianLan --> TrangThaiBaoCao

    YeuCauDangKy --> TrangThaiYeuCauDangKy
    YeuCauDangKy --> LyDoTuChoi
    YeuCauDangKy --> LoaiToChucDangKy

    GiayPhepCSDT --> KieuGiayPhepCSDT
    GiayPhepCSDT --> TrangThaiXacMinhGiayPhep
    GiayPhepNhaTuyenDung --> KieuGiayPhepNTD
    GiayPhepNhaTuyenDung --> TrangThaiXacMinhGiayPhep

    UyTinToChuc --> HangUyTin